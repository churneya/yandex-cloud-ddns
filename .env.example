# Yandex Cloud identifiers.
YC_CLOUD_ID=
YC_FOLDER_ID=
YC_DNS_ZONE_ID=

# Authorized key JSON for the service account.
# Keep this value out of git. It may be a single-line JSON string.
YC_SERVICE_ACCOUNT_KEY_JSON=

# DNS record to update. The record must already exist.
DNS_RECORD_NAME=home.churneya.ru.
DNS_RECORD_TYPE=A
DNS_RECORD_TTL=60

# 15 minutes by default.
CHECK_INTERVAL_SECONDS=900

# Comma-separated fallback list. The first valid IPv4 response is used.
PUBLIC_IP_URLS=https://api.ipify.org,https://ifconfig.me/ip,https://icanhazip.com,https://checkip.amazonaws.com
PUBLIC_IP_TIMEOUT_SECONDS=10

# Published by GitHub Actions.
DDNS_IMAGE=ghcr.io/churneya/yandex-cloud-ddns:latest
